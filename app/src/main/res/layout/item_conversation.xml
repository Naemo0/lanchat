<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:text="👤"
        android:textSize="24sp"
        android:gravity="center"
        android:background="@drawable/bg_status_dot"
        android:backgroundTint="#F5F5F5"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvConvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="اسم المحادثة"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvConvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00 م"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvConvLastMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="آخر رسالة هنا..."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvUnreadBadge"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_send_button"
        android:textColor="@color/text_on_primary"
        android:textSize="10sp"
        android:gravity="center"
        android:text="1"
        android:visibility="gone"
        android:layout_marginStart="8dp"/>
</LinearLayout>
